{
  "name": "labpulse",
  "version": "1.0.0",
  "description": "Operations Intelligence Dashboard for Dental Laboratory Management",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "setup": "npm install && npm run prisma:generate && npm run prisma:migrate",
    "prisma:generate": "npm run prisma:generate --workspace=server",
    "prisma:migrate": "npm run prisma:migrate --workspace=server",
    "prisma:seed": "npm run prisma:seed --workspace=server",
    "prisma:studio": "npm run prisma:studio --workspace=server"
  },
  "keywords": [
    "dashboard",
    "operations",
    "analytics",
    "dental-lab"
  ],
  "author": "LabPulse Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
